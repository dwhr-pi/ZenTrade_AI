{
  "name": "zenbot-multi-user-pm2",
  "version": "1.0.0",
  "description": "PM2-basierte Multi-User-Lösung für Zenbot",
  "main": "ecosystem.config.js",
  "scripts": {
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "restart": "pm2 restart ecosystem.config.js",
    "reload": "pm2 reload ecosystem.config.js",
    "delete": "pm2 delete ecosystem.config.js",
    "status": "pm2 status",
    "logs": "pm2 logs",
    "monit": "pm2 monit",
    "setup": "npm run create-dirs && npm run copy-configs",
    "create-dirs": "mkdir -p logs && mkdir -p configs",
    "copy-configs": "echo 'Kopieren Sie Ihre Zenbot-Konfigurationsdateien in das configs/ Verzeichnis'",
    "install-pm2": "npm install -g pm2",
    "save-pm2": "pm2 save",
    "startup-pm2": "pm2 startup"
  },
  "keywords": [
    "zenbot",
    "trading",
    "bot",
    "cryptocurrency",
    "pm2",
    "multi-user"
  ],
  "author": "Manus AI",
  "license": "MIT",
  "devDependencies": {
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}

