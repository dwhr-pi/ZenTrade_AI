{
  "name": "zenbot4",
  "version": "4.1.0",
  "description": "Cryptocurrency trading bot",
  "bugs": "https://github.com/deviavir/zenbot/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deviavir/zenbot.git"
  },
  "main": "./index.js",
  "bin": {
    "zenbot": "./zenbot.sh"
  },
  "scripts": {
    "lint": "eslint **/*.js",
    "lint-fix": "eslint **/*.js --fix",
    "precommit": "lint-staged",
    "test": "jasmine test/**/**.test.js",
    "test-one": "jasmine $PATH_TO_TEST",
    "test:sql-compat": "node ./scripts/test-sql-compat.js",
    "test:db-interface-handover": "node ./scripts/test-db-interface-handover.js",
    "test:db-interface-handover:log": "node ./scripts/run-and-log.js db-interface-handover.log node ./scripts/test-db-interface-handover.js",
    "test:backfill-sim-e2e": "node ./scripts/test-backfill-sim-e2e.js",
    "test:backfill-sim-e2e:log": "node ./scripts/run-and-log.js backfill-sim-e2e.log node ./scripts/test-backfill-sim-e2e.js",
    "test:strategy-integrations": "node ./scripts/test-strategy-integrations.js",
    "test:strategy-integrations:log": "node ./scripts/run-and-log.js strategy-integrations.log npm run test:strategy-integrations",
    "test:copy-trading-signal": "node ./scripts/validate-copy-trading-signal.js",
    "test:copy-trading-signal:log": "node ./scripts/run-and-log.js copy-trading-signal-validation.log node ./scripts/validate-copy-trading-signal.js",
    "test:copy-trading-scenario": "node ./scripts/test-copy-trading-scenario.js",
    "test:copy-trading-scenario:log": "node ./scripts/run-and-log.js copy-trading-scenario.log node ./scripts/test-copy-trading-scenario.js",
    "test:risk-analysis-file": "jasmine test/lib/risk-analysis-file.test.js",
    "test:risk-analysis-file:log": "node ./scripts/run-and-log.js risk-analysis-file.log npm run test:risk-analysis-file",
    "diagnose": "node ./scripts/diagnose-install.js --write",
    "install:log": "node ./scripts/run-and-log.js install.log npm install --foreground-scripts",
    "sim:copy-trading-sql:report": "node ./scripts/run-and-report.js copy-trading-file-sql-sim-report.log runtime 120000 node ./zenbot.js sim stub.BTC-USD --conf ./conf-examples/copy-trading-file-sql.conf.js --strategy copy_trading_file --days 1",
    "sim:copy-trading-scenario-sql": "node ./zenbot.js sim stub.BTC-USD --conf ./conf-examples/copy-trading-file-scenario-sql.conf.js --strategy copy_trading_file --days 1",
    "sim:copy-trading-scenario-sql:report": "node ./scripts/run-and-report.js copy-trading-file-scenario-sql-report.log runtime 120000 node ./zenbot.js sim stub.BTC-USD --conf ./conf-examples/copy-trading-file-scenario-sql.conf.js --strategy copy_trading_file --days 1",
    "export:access": "node ./scripts/export-access-package.js",
    "postinstall": "node post_install.js",
    "snyk-protect": "snyk protect",
    "prepare": "npm run snyk-protect"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "git add"
    ]
  },
