    "node-telegram-bot-api": "^0.50.0",
    "number-abbreviate": "^2.0.0",
    "numbro": "github:highvelocityspace/numbro",
    "path": "^0.12.7",
    "poloniex.js": "1.0.1",
    "popper.js": "^1.16.1",
    "postcss-loader": "^3.0.0",
    "progress": "^2.0.0",
    "pushbullet": "2.4.0",
    "pusher-js": "^5.1.1",
    "quadrigacx": "0.0.7",
    "random-port": "^0.1.0",
    "regression": "^2.0.0",
    "resolve-url-loader": "^3.1.1",
    "sass-loader": "^8.0.2",
    "semver": "^7.3.2",
    "simple-xmpp": "^1.3.0",
    "stats-lite": "2.2.0",
    "style-loader": "^1.2.1",
    "superagent": "^5.3.1",
    "talib": "^1.1.3",
    "timebucket": "^0.4.0",
    "trend": "0.3.0",
    "tulind": "^0.8.18",
    "url-loader": "^4.1.0",
    "waypoints": "^4.0.1",
    "webpack": "^4.44.1",
    "webpack-cli": "^3.3.12",
    "wexnz": "^0.1.3",
    "ws": "^7.3.1",
    "zero-fill": "^2.2.4",
    "snyk": "^1.374.0"
  },
  "devDependencies": {
    "eslint": "^4.19.1",
    "geneticalgorithm": "^1.0.1",
    "json2csv": "^5.0.0",
    "round-precision": "^1.0.0",
